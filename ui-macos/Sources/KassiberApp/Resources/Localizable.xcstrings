    "connections.silentPayment.fullHistoryAck": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mir ist bewusst, dass ein vollständiger Silent-Payments-Historienscan langsam und ressourcenintensiv sein kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I understand that a full-history Silent Payments scan can be slow and resource intensive."
          }
        }
      }
    },
