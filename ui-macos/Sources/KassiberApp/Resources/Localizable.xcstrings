    "privacy.reco.address_reuse": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Wiederverwendung einer Empfangsadresse verknüpft ihre Zahlungen. Verwende nach Möglichkeit für jeden Eingang eine neue Adresse."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reusing a receive address links its payments. Use a fresh address for each receipt when possible."
          }
        }
      }
    },
    "privacy.reco.ai": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende einen lokalen Anbieter, wenn Assistant-Anfragen auf diesem Mac bleiben müssen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a local provider when assistant prompts must stay on this Mac."
          }
        }
      }
    },
    "privacy.reco.change_output": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechselgeld kann die Wallet-Struktur verraten. Nutze gleiche Skripttypen und frische Adressen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change can reveal wallet structure. Use matching script types and fresh addresses."
          }
        }
      }
    },
    "privacy.reco.common_input": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib Coins aus verschiedenen Clustern nicht in einer Transaktion aus — gemeinsame Inputs verknüpfen sie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Avoid spending coins from different clusters in one transaction — a shared input links them."
          }
        }
      }
    },
    "privacy.reco.coverage_degraded": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Analyse ist unvollständig — synchronisiere oder importiere fehlende Transaktionsdetails."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Analysis is incomplete — sync or import missing transaction detail to strengthen it."
          }
        }
      }
    },
    "privacy.reco.fallback": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüfe diesen Eintrag auf Privatsphäre-Offenlegung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Review this item for privacy exposure."
          }
        }
      }
    },
    "privacy.reco.fee_fingerprint": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine auffällige Gebührenrate grenzt den Wallet-Kreis ein. Nutze nach Möglichkeit übliche Gebührenraten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A distinctive fee rate narrows the wallet set. Match common fee rates where you can."
          }
        }
      }
    },
    "privacy.reco.inventory": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behandle lokale Adress-, Skript- und Ableitungsmetadaten als sensibel und halte die Datenbank verschlüsselt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Treat local address, script, and derivation metadata as sensitive and keep the database encrypted."
          }
        }
      }
    },
    "privacy.reco.journals": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kläre datenschutzbezogene Journal-Prüfpunkte, bevor du abgeleitete Berichte verwendest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Resolve privacy-related journal review items before relying on derived reports."
          }
        }
      }
    },
    "privacy.reco.network": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende dein eigenes Backend oder einen datenschutzfreundlichen Proxy, wenn Drittanbieter deine Abfragen nicht sehen sollen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use your own backend or a privacy-preserving proxy when third-party query visibility is not acceptable."
          }
        }
      }
    },
    "privacy.reco.op_return_output": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "OP_RETURN-Daten sind öffentlich und dauerhaft. Vermeide identifizierende Metadaten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OP_RETURN data is public and permanent. Avoid attaching identifying metadata."
          }
        }
      }
    },
    "privacy.reco.sender_common_input": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib Coins aus verschiedenen Clustern nicht in einer Transaktion aus — gemeinsame Inputs verknüpfen sie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Avoid spending coins from different clusters in one transaction — a shared input links them."
          }
        }
      }
    },
    "privacy.reco.sender_rbf": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Replace-by-Fee ist on-chain sichtbar und kann das Wallet-Verhalten verraten. Behandle es als Kontext zur Transaktionsform."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replace-by-fee is visible on-chain and can fingerprint wallet behavior. Treat it as transaction-shape context."
          }
        }
      }
    },
    "privacy.reco.source_proximity_coverage_gaps": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einige eigene Coins haben keine geprüfte Quellen-Nähe. Importiere oder prüfe ihre Historie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some owned coins lack reviewed source-funds proximity. Import or review their history to complete the picture."
          }
        }
      }
    },
    "privacy.reco.storage": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschlüssle dieses Buch mit SQLCipher, wenn die lokale Datenbank im Ruhezustand geschützt sein soll."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Encrypt this book with SQLCipher if its local database should be protected at rest."
          }
        }
