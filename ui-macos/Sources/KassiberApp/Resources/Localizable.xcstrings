    "connections.silentPayment.serverAck": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mir ist bewusst, dass dieses Backend genug erfahren kann, um diese Silent-Payments-Wallet zu korrelieren, und unvollständige Scankandidaten Berichte unvollständig machen können. Nicht auf ein anderes Backend ausweichen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I understand that this backend may learn enough to correlate this Silent Payments wallet, and incomplete scan candidates can make reports incomplete. Do not fall back to another backend."
          }
        }
      }
    },
