    },
    "privacy.reco.transactions": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüfe Datenschutzgrenzen und füge stärkere lokale Herkunftsnachweise hinzu, wenn die Grenze relevant ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
