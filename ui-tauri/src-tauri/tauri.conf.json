{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kassiber",
  "version": "0.22.55",
  "identifier": "at.bitcoinaustria.kassiber",
  "build": {
    "beforeDevCommand": "pnpm dev --host 127.0.0.1",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1760,
        "height": 1160,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "resources": [
      "binaries/",
      "bin/",
      "windows/update-path.ps1"
    ],
    "linux": {
      "deb": {
        "provides": [
          "kassiber-command"
        ],
        "conflicts": [
          "kassiber-cli"
        ],
        "replaces": [
          "kassiber-cli"
        ],
        "files": {
          "/usr/bin/kassiber": "bin/kassiber-linux"
        }
      }
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/installer-hooks.nsh",
        "installMode": "currentUser"
      },
      "wix": {
        "fragmentPaths": [
          "./windows/fragments/cli-path.wxs"
        ],
        "componentRefs": [
          "KassiberCliPath"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "kassiber"
        ]
      }
    }
  }
}
