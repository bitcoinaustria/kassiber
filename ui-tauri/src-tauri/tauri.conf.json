{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kassiber",
  "version": "0.21.0",
  "identifier": "at.bitcoinaustria.kassiber",
  "build": {
    "beforeDevCommand": "pnpm dev --host 127.0.0.1",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kassiber",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
