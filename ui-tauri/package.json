{
  "name": "kassiber-ui",
  "version": "0.22.55",
  "private": true,
  "description": "Kassiber desktop UI — Tauri 2 + React 19 frontend with a Python daemon transport.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:browser": "VITE_DAEMON=bridge KASSIBER_DEV_DATA_ROOT=\"${KASSIBER_REGTEST_DEMO_HOME:-$HOME/.kassiber/regtest-demo}/data\" vite",
    "dev:bridge": "VITE_DAEMON=bridge vite",
    "dev:demo": "VITE_DAEMON=bridge KASSIBER_DEV_DATA_ROOT=\"${KASSIBER_REGTEST_DEMO_HOME:-$HOME/.kassiber/regtest-demo}/data\" vite",
    "dev:shell": "tauri dev",
    "build": "tsc -b && vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "blocks:add:dashboard5": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; if [ -z \"${SHADCNBLOCKS_API_KEY:-}\" ] || [ \"$SHADCNBLOCKS_API_KEY\" = \"replace_with_your_shadcnblocks_api_key\" ]; then echo \"Set SHADCNBLOCKS_API_KEY in ui-tauri/.env first\" >&2; exit 1; fi; pnpm dlx shadcn@latest add @shadcnblocks/dashboard5'"
  },
  "dependencies": {
    "@fontsource/blinker": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@tanstack/react-query": "^5.71.1",
    "@tanstack/react-router": "^1.114.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "25.8.18",
    "lucide-react": "^0.469.0",
    "pako": "^2.1.0",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "16.5.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-devtools": "^1.114.3",
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^22.10.5",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jiti": "^2.6.1",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.4.3",
    "vitest": "3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}
