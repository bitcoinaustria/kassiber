# Kassiber loads named sync backends from this file.
# Default location: ~/.kassiber/config/backends.env
# `mempool` is built in by default, so this file is optional.
#
# Use this file for non-secret addressing only: KIND, URL, CHAIN,
# NETWORK, BATCH_SIZE, TIMEOUT, INSECURE, WALLETPREFIX, COOKIEFILE
# (path), and KASSIBER_DEFAULT_BACKEND.
#
# Tokens, passwords, auth headers, and basic-auth usernames are NOT
# safe to keep here once the local database is encrypted with
# `kassiber secrets init` — this file lives plaintext on disk. Seed
# new credentials directly into the encrypted backends table with
# `--token-stdin` / `--token-fd FD` (and the matching --password /
# --auth-header / --username variants), or lift any pre-existing
# entries with `kassiber secrets migrate-credentials`.

KASSIBER_DEFAULT_BACKEND=mempool

KASSIBER_BACKEND_MEMPOOL_KIND=esplora
KASSIBER_BACKEND_MEMPOOL_URL=https://mempool.space/api

# Example self-hosted Electrum / Fulcrum backend
# KASSIBER_BACKEND_BLOCKSTREAM_KIND=electrum
# KASSIBER_BACKEND_BLOCKSTREAM_URL=ssl://electrum.blockstream.info:50002
# KASSIBER_BACKEND_BLOCKSTREAM_TIMEOUT=30

# Example Bitcoin Core backend (cookiefile auth, no secrets in dotenv)
# KASSIBER_BACKEND_CORE_KIND=bitcoinrpc
# KASSIBER_BACKEND_CORE_URL=http://127.0.0.1:8332
# KASSIBER_BACKEND_CORE_COOKIEFILE=~/.bitcoin/.cookie
# KASSIBER_BACKEND_CORE_WALLETPREFIX=kassiber

# RPC username / password are SECRETS — do NOT leave them here once
# `kassiber secrets init` has run. Migrate them into the encrypted DB:
#
#     printf %s "$RPC_PASS" | kassiber backends update core --password-stdin
#     # ...or, for an existing dotenv entry:
#     kassiber secrets migrate-credentials
